---
import type { Pub } from "../utils/bibtex";

interface Props {
  groups: { year: string; items: Pub[] }[];
}
const { groups } = Astro.props;

function venueLine(p: Pub): string {
  const bits: string[] = [];
  if (p.venue) bits.push(p.venue);
  const vn = [p.volume, p.number ? `(${p.number})` : ""].filter(Boolean).join("");
  if (vn) bits.push(vn);
  if (p.pages) bits.push(p.pages);
  let s = bits.join(", ");
  if (p.year) s += `${s ? " " : ""}(${p.year})`;
  return s;
}
---

<div class="space-y-8">
  {
    groups.map((g) => (
      <section class="prose-measure">
        <h3 class="muted mb-3 font-mono text-sm tracking-wide">{g.year}</h3>
        <ol class="space-y-5">
          {g.items.map((p) => (
            <li class="border-l-2 pl-4" style="border-color: var(--border);">
              <p class="leading-snug">
                {p.authors.map((a, i) => (
                  <>
                    {i > 0 && ", "}
                    {a.self ? (
                      <strong style="color: var(--fg);">{a.display}</strong>
                    ) : (
                      a.display
                    )}
                    {a.equal && <sup>†</sup>}
                  </>
                ))}
              </p>
              <p class="mt-1 font-medium" style="color: var(--fg);">
                {p.title}
              </p>
              <p class="muted mt-0.5 text-sm">
                <em>{venueLine(p)}</em>
                {p.note && <span> · {p.note}</span>}
              </p>
              <div class="mt-2 flex flex-wrap gap-2">
                {(p.pdf || p.url) && (
                  <a class="btn" href={p.pdf ?? p.url} target="_blank" rel="noopener">
                    PDF
                  </a>
                )}
                {p.code && (
                  <a class="btn" href={p.code} target="_blank" rel="noopener">
                    Code
                  </a>
                )}
                {p.doi && (
                  <a class="btn" href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">
                    DOI
                  </a>
                )}
                <button class="btn js-bib" type="button" data-bibtex={p.raw}>
                  BibTeX
                </button>
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))
  }
</div>
