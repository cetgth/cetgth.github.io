---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../config";
import { url } from "../utils/url";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${site.name.en}` : site.name.en;
const desc =
  description ?? `${site.name.en} — ${site.position}, ${site.affiliation.lab}.`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href={url("favicon.svg")} />
    <meta name="color-scheme" content="light dark" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta name="twitter:card" content="summary" />

    <!-- Fonts (Google Fonts incl. Korean Noto). swap = no invisible text. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- No-flash dark mode: runs before paint -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("theme");
          const dark =
            t === "dark" ||
            (!t && matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="shell w-full flex-1 py-10 sm:py-14">
      <slot />
    </main>
    <Footer />
  </body>
</html>
