---
import BaseLayout from "../layouts/BaseLayout.astro";

// Datasets you can list. Add `href` to link, `status` for a badge.
const datasets = [
  {
    name: "Contour-EEG",
    desc: "32-ch EEG during melodic listening / imagery / production. N=30.",
    status: "Available on request",
  },
];
---

<BaseLayout title="Resources" description="Code, data, and tools.">
  <header class="prose-measure">
    <h1 class="text-3xl">Code & Data</h1>
    <p class="muted mt-2">
      Code, datasets, and tools from my research — released here as they become
      available.
    </p>
  </header>

  <section class="mt-8">
    <h2 class="text-lg">Repositories</h2>
    <p class="mt-3"><span class="tag">TBD</span></p>
  </section>

  <section class="mt-10">
    <h2 class="text-lg">Datasets</h2>
    <ul class="mt-4 space-y-3">
      {
        datasets.map((d) => (
          <li class="prose-measure">
            {d.href ? (
              <a href={d.href} target="_blank" rel="noopener">
                {d.name}
              </a>
            ) : (
              <span class="font-medium" style="color: var(--fg);">
                {d.name}
              </span>
            )}
            {d.status && <span class="tag ml-2">{d.status}</span>}
            <span class="muted"> — {d.desc}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-lg">Software / Toolboxes</h2>
    <p class="mt-3"><span class="tag">TBD</span></p>
  </section>
</BaseLayout>
