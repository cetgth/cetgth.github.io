---
import BaseLayout from "../layouts/BaseLayout.astro";

// Edit these arrays to list your repos / datasets / tools.
// Add `href` to make an item a link; add `status` (e.g. "TBD", "Not yet public")
// to show a badge. Items without href render as plain text (no broken links).
const repos = [
  {
    name: "eeg-contour",
    desc: "EEG melodic-contour decoding pipeline (MNE-Python + scikit-learn).",
    lang: "Python",
    status: "TBD",
  },
  {
    name: "music-bci-rt",
    desc: "Real-time music-imagery BCI prototype and calibration utilities.",
    lang: "Python",
    status: "TBD",
  },
];

const datasets = [
  {
    name: "Contour-EEG",
    desc: "32-ch EEG during melodic listening / imagery / production. N=30.",
    status: "Not yet public",
  },
];

const tools = [
  {
    name: "contourkit",
    desc: "Small toolbox for representing and scoring melodic contours.",
    status: "TBD",
  },
];
---

<BaseLayout title="Resources" description="Code, data, and tools.">
  <header class="prose-measure">
    <h1 class="text-3xl">Code & Data</h1>
    <p class="muted mt-2">
      Code, datasets, and tools from my research. Several are in progress —
      links will appear here as they are released.
    </p>
  </header>

  <section class="mt-8">
    <h2 class="text-lg">Repositories</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {
        repos.map((r) => {
          const Tag = r.href ? "a" : "div";
          return (
            <Tag
              class="card block no-underline"
              href={r.href}
              target={r.href ? "_blank" : undefined}
              rel={r.href ? "noopener" : undefined}
            >
              <div class="flex items-center justify-between gap-2">
                <span class="font-mono font-semibold" style="color: var(--fg);">
                  {r.name}
                </span>
                <span class="flex shrink-0 items-center gap-1.5">
                  {r.lang && <span class="tag">{r.lang}</span>}
                  {r.status && <span class="tag">{r.status}</span>}
                </span>
              </div>
              <p class="muted mt-2 text-sm">{r.desc}</p>
            </Tag>
          );
        })
      }
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-lg">Datasets</h2>
    <ul class="mt-4 space-y-3">
      {
        datasets.map((d) => (
          <li class="prose-measure">
            {d.href ? (
              <a href={d.href} target="_blank" rel="noopener">
                {d.name}
              </a>
            ) : (
              <span class="font-medium" style="color: var(--fg);">
                {d.name}
              </span>
            )}
            {d.status && <span class="tag ml-2">{d.status}</span>}
            <span class="muted"> — {d.desc}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-lg">Software / Toolboxes</h2>
    <ul class="mt-4 space-y-3">
      {
        tools.map((t) => (
          <li class="prose-measure">
            {t.href ? (
              <a href={t.href} target="_blank" rel="noopener">
                {t.name}
              </a>
            ) : (
              <span class="font-medium" style="color: var(--fg);">
                {t.name}
              </span>
            )}
            {t.status && <span class="tag ml-2">{t.status}</span>}
            <span class="muted"> — {t.desc}</span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
