---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
import { url } from "../utils/url";
---

<BaseLayout title="CV" description="Curriculum vitae.">
  <div class="prose-measure longform">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h1 class="text-3xl">Curriculum Vitae</h1>
      <a class="btn btn-accent" href={url(site.cvPdf)} download>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v12m0 0 4-4m-4 4-4-4"></path>
          <path d="M5 21h14"></path>
        </svg>
        Download PDF
      </a>
    </div>
    <p class="muted mt-2 text-sm">
      Last updated June 2026 · the PDF is the authoritative version.
    </p>

    <h2>Education</h2>
    <ul>
      <li>
        <strong>Integrated M.S.–Ph.D., Biomedical Engineering</strong> — UNIST,
        BCI Lab (2023–present)
      </li>
      <li>
        <strong>B.S., Chemical, Biological and Environmental Engineering</strong>
        — Pusan National University (2019–2023)
      </li>
    </ul>

    <h2>Research experience</h2>
    <ul>
      <li>
        <strong>Graduate Researcher</strong>, {site.affiliation.lab}, UNIST
        (2023–present) — EEG decoding of musical pitch and melody imagery;
        closed-loop music-imagery BCIs.
      </li>
      <li>
        <strong>Undergraduate Researcher</strong>, Water Treatment and Reuse
        (WATER) Lab — Pusan National University (2021–2022).
      </li>
    </ul>

    <h2>Grants & Fellowships</h2>
    <ul>
      <li>
        <strong>Doctoral Student Research Grant</strong>, National Research
        Foundation of Korea (NRF), 2025–2027 — Principal Investigator.
        <em>Real-Time Playback of <strong>Imagined Melodies</strong> via a
        Closed-Loop Noninvasive EEG Brain–Computer Interface.</em>
      </li>
      <li>
        <strong>Core Research Program (Type B), National Research Foundation of Korea (NRF)</strong>, 2025–2030 —
        Participating Researcher. <em>Music Braincoder: Development of a
        noninvasive brain–computer interface for reproducing <strong>imagined
        music</strong> and enhancing musical performance.</em>
      </li>
    </ul>

    <h2>Publications</h2>
    <p>
      See the <a href={url("publications")}>full list</a>.
    </p>
    <ul>
      <li>
        Kim, J., <strong>Yoon, C.-E.</strong>, Seo, S., & Kim, S.-P. (2026).
        Real-Time Single-Trial Decoding in a Calibration-Free P300-Based BCI
        Using a Compact Eight-Channel EEG Configuration. <em>Int. Conf. on
        Brain–Computer Interface (BCI)</em>, 1–6.
      </li>
    </ul>

    <h2>Conference presentations</h2>
    <ul>
      <li>
        <strong>2026</strong> — Poster (forthcoming), Society for Neuroscience
        (SfN). Decoding Melodic Contour from Human Electroencephalography during
        Music Listening, Imagery, and Production.
      </li>
      <li>
        <strong>2026</strong> — Poster (forthcoming), Brain Engineering Society of
        Korea (BESK), Jeju, Korea. Decoding Melodic Contour from Human
        Electroencephalography Using Spectral Patterns.
      </li>
      <li>
        <strong>2025</strong> — Poster, Society for Neuroscience (SfN). Effects of
        Visual Cues on Musical Melody Imagery for EEG-based BCIs.
      </li>
      <li>
        <strong>2025</strong> — Poster, International Society for Music Information
        Retrieval (ISMIR). Neural Representation of Musical Pitch During Music
        Perception and Imagery.
      </li>
      <li>
        <strong>2023</strong> — Poster, 5th International Conference on Emotion and
        Sensibility (ICES), Jeju, Korea. Design of Visual Guidance for Musical
        Pitch Imagery.
      </li>
    </ul>

    <h2>Teaching</h2>
    <ul>
      <li>
        <strong>Teaching Assistant</strong>, Brain & Cognitive Engineering —
        UNIST (Fall 2025).
      </li>
      <li>
        <strong>Teaching Assistant</strong>, AI-based Neural Data Science —
        UNIST (Spring 2024).
      </li>
    </ul>
  </div>
</BaseLayout>
