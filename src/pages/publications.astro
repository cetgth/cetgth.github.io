---
import BaseLayout from "../layouts/BaseLayout.astro";
import PubList from "../components/PubList.astro";
import { site } from "../config";
import { parseBibtex, groupByYear } from "../utils/bibtex";
// Vite ?raw import → the .bib file content as a string (parsed at build time).
import bibRaw from "../data/publications.bib?raw";

const pubs = parseBibtex(bibRaw, { selfSurnames: [...site.selfSurnames] });
const isTalk = (k: string) => ["poster", "talk", "presentation"].includes(k);
const papers = groupByYear(pubs.filter((p) => !isTalk(p.kind)));
const talks = groupByYear(pubs.filter((p) => isTalk(p.kind)));
---

<BaseLayout
  title="Publications"
  description="Publications and conference presentations."
>
  <header class="prose-measure">
    <h1 class="text-3xl">Publications &amp; Presentations</h1>
    <p class="muted mt-2">
      <span class="font-semibold" style="color: var(--fg);">Bold</span> = me. † =
      equal contribution.
    </p>
  </header>

  {
    papers.length > 0 && (
      <section class="mt-9">
        <h2 class="prose-measure text-xl">Publications</h2>
        <div class="mt-4">
          <PubList groups={papers} />
        </div>
      </section>
    )
  }

  {
    talks.length > 0 && (
      <section class="mt-12">
        <h2 class="prose-measure text-xl">Presentations</h2>
        <div class="mt-4">
          <PubList groups={talks} />
        </div>
      </section>
    )
  }

  <script is:inline>
    document.querySelectorAll(".js-bib").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-bibtex") || "";
        try {
          await navigator.clipboard.writeText(text);
          const old = btn.textContent;
          btn.textContent = "Copied ✓";
          setTimeout(() => (btn.textContent = old), 1200);
        } catch (e) {
          window.prompt("Copy BibTeX:", text);
        }
      });
    });
  </script>
</BaseLayout>
