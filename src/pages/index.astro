---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
import { url } from "../utils/url";
import { parseBibtex } from "../utils/bibtex";
import bibRaw from "../data/publications.bib?raw";

const news = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const projects = (await getCollection("research"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const pubs = parseBibtex(bibRaw, { selfSurnames: [...site.selfSurnames] });
const selected = pubs.filter((p) => p.selected).slice(0, 3);

const email = site.links.email ?? "";
const [emailUser, emailDomain] = email.includes("@") ? email.split("@") : ["", ""];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout bleed>
  <!-- ── HERO (full-screen landing: name + simple intro only) ─────────────── -->
  <section class="hero relative">
    <div id="notes-field" class="notes-field" aria-hidden="true"></div>

    <div
      class="shell relative z-10 flex min-h-[calc(100dvh-3.5rem)] flex-col items-center justify-center py-20 text-center"
    >
      <div class="avatar">
        <img
          src={url(site.photo)}
          alt={site.name.en}
          width="120"
          height="120"
          loading="eager"
          class="h-28 w-28 rounded-2xl object-cover"
        />
      </div>

      <p class="kicker mt-7">
        {site.position} · {site.affiliation.lab} · {site.affiliation.university}
      </p>
      <h1 class="mt-4 text-5xl font-bold sm:text-6xl">
        <span class="name-grad">{site.name.en}</span>
      </h1>
      <p class="muted mt-2 text-lg">{site.name.ko}</p>
      <p class="lead mt-5 max-w-xl">{site.interests}.</p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-2.5">
        <a
          class="btn btn-accent js-email"
          data-user={emailUser}
          data-domain={emailDomain}
          href="#"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg>
          Email
        </a>
        <a class="btn" href={url(site.cvPdf)} download>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4"></path><path d="M5 21h14"></path></svg>
          CV
        </a>
        {
          site.links.github && (
            <a class="btn" href={site.links.github} target="_blank" rel="noopener">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7 0-.7 0-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 5 18 5c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" /></svg>
              GitHub
            </a>
          )
        }
        <button
          id="play-melody"
          class="btn"
          type="button"
          aria-label="Play a short melody"
          aria-pressed="false"
        >
          <svg class="play-ico h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg>
          <svg class="pause-ico hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 5h3.5v14H7zM13.5 5H17v14h-3.5z"></path></svg>
          <span class="play-txt">Play melody</span>
        </button>
      </div>
    </div>

    <!-- scroll-down cue -->
    <a href="#more" class="scroll-cue" aria-label="Scroll for more">
      <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
    </a>
  </section>

  <!-- ── BELOW THE FOLD (scroll, or use the menu tabs) ────────────────────── -->
  <div id="more" class="shell scroll-mt-20">
    <!-- RESEARCH -->
    <section class="reveal pt-16 sm:pt-24">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="kicker">Selected work</p>
          <h2 class="mt-2 text-2xl sm:text-3xl">Research</h2>
        </div>
        <a class="link-arrow" href={url("research")}>
          View all
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"></path></svg>
        </a>
      </div>

      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {
          projects.map((p) => (
            <a
              class="card group flex flex-col overflow-hidden !p-0 no-underline"
              href={p.data.pub ?? url("research")}
              target={p.data.pub ? "_blank" : undefined}
              rel={p.data.pub ? "noopener" : undefined}
            >
              {p.data.image && (
                <div class="card-media aspect-[16/10] w-full">
                  <img
                    src={url(p.data.image)}
                    alt={p.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-4">
                <h3 class="text-base" style="color: var(--fg);">
                  {p.data.title}
                </h3>
                <p class="muted mt-1.5 text-sm leading-relaxed">{p.data.summary}</p>
                {p.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {p.data.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- SELECTED PUBLICATIONS -->
    <section class="reveal pt-16 sm:pt-24">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="kicker">Recent</p>
          <h2 class="mt-2 text-2xl sm:text-3xl">Selected publications</h2>
        </div>
        <a class="link-arrow" href={url("publications")}>
          All publications
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"></path></svg>
        </a>
      </div>

      <ol class="mt-6 space-y-4">
        {
          selected.map((p) => (
            <li class="card">
              <p class="leading-snug">
                {p.authors.map((a, i) => (
                  <>
                    {i > 0 && ", "}
                    {a.self ? (
                      <strong style="color: var(--fg);">{a.display}</strong>
                    ) : (
                      a.display
                    )}
                    {a.equal && <sup>†</sup>}
                  </>
                ))}
              </p>
              <p class="mt-1 font-medium" style="color: var(--fg);">
                {p.title}
              </p>
              <p class="muted mt-0.5 text-sm">
                <em>
                  {p.venue}
                  {p.year ? ` (${p.year})` : ""}
                </em>
                {p.note && <span> · {p.note}</span>}
              </p>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- NEWS -->
    <section class="reveal pb-6 pt-16 sm:pt-24">
      <p class="kicker">Updates</p>
      <h2 class="mt-2 text-2xl sm:text-3xl">News</h2>
      <ul class="mt-6 max-w-2xl space-y-3">
        {
          news.map((item) => (
            <li class="flex flex-col gap-0.5 sm:flex-row sm:gap-4">
              <time
                datetime={item.data.date.toISOString()}
                class="muted shrink-0 font-mono text-sm sm:w-28"
              >
                {fmt(item.data.date)}
              </time>
              <span>
                {item.data.link ? (
                  <a class="ulink" href={item.data.link} target="_blank" rel="noopener">
                    {item.data.title}
                  </a>
                ) : (
                  item.data.title
                )}
              </span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>

  <!-- ── Floating pastel music glyphs (drift + mouse-repel) + playable melody ─ -->
  <script is:inline>
    (() => {
      const field = document.getElementById("notes-field");
      if (!field) return;
      const hero = field.closest(".hero");
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

      const PASTELS = [
        "#5eead4", "#99f6e4", "#a7f3d0", "#bae6fd",
        "#c7d2fe", "#ddd6fe", "#fbcfe8", "#fde68a", "#a5f3fc",
      ];
      const TYPES = ["eighth", "eighth", "eighth", "beamed", "beamed", "quarter", "quarter", "clef"];

      function glyphSVG(type, c, s) {
        if (type === "quarter")
          return `<svg viewBox="0 0 30 50" width="${s}" height="${(s * 50) / 30}"><ellipse cx="11" cy="39" rx="8.5" ry="6.5" transform="rotate(-22 11 39)" fill="${c}"/><path d="M18.2 38 V9" fill="none" stroke="${c}" stroke-width="3.4" stroke-linecap="round"/></svg>`;
        if (type === "eighth")
          return `<svg viewBox="0 0 36 50" width="${s}" height="${(s * 50) / 36}"><ellipse cx="12" cy="39" rx="8.5" ry="6.5" transform="rotate(-22 12 39)" fill="${c}"/><path d="M19 38 V9" fill="none" stroke="${c}" stroke-width="3.4" stroke-linecap="round"/><path d="M19 9 c10 2 12 11 6 18" fill="none" stroke="${c}" stroke-width="3.2" stroke-linecap="round"/></svg>`;
        if (type === "beamed")
          return `<svg viewBox="0 0 50 50" width="${s * 1.3}" height="${(s * 50) / 50 * 1.3}"><ellipse cx="11" cy="40" rx="8" ry="6" transform="rotate(-22 11 40)" fill="${c}"/><ellipse cx="34" cy="40" rx="8" ry="6" transform="rotate(-22 34 40)" fill="${c}"/><path d="M18 40 V13" fill="none" stroke="${c}" stroke-width="3.2" stroke-linecap="round"/><path d="M41 40 V13" fill="none" stroke="${c}" stroke-width="3.2" stroke-linecap="round"/><path d="M17 14 H42" fill="none" stroke="${c}" stroke-width="5" stroke-linecap="round"/></svg>`;
        // treble clef — real glyph from the Noto Music webfont
        return `<span style="font-family:'Noto Music',serif;font-size:${(s * 1.9) | 0}px;line-height:1;color:${c};display:block;">𝄞</span>`;
      }

      let W = 0, H = 0;
      const measure = () => {
        const r = hero.getBoundingClientRect();
        W = r.width; H = r.height;
      };
      measure();
      window.addEventListener("resize", measure);

      const N = Math.max(10, Math.min(22, Math.round(window.innerWidth / 85)));
      const rnd = (a, b) => a + Math.random() * (b - a);
      const glyphs = [];
      for (let i = 0; i < N; i++) {
        const type = TYPES[(Math.random() * TYPES.length) | 0];
        const color = PASTELS[(Math.random() * PASTELS.length) | 0];
        const size = rnd(22, 50);
        const el = document.createElement("div");
        el.className = "note-glyph";
        el.innerHTML = glyphSVG(type, color, size);
        field.appendChild(el);
        const g = {
          el,
          x: rnd(0, W), y: rnd(0, H),
          vx: rnd(-0.28, 0.28), vy: -rnd(0.12, 0.36),
          rot: rnd(-22, 22), vr: rnd(-0.18, 0.18),
          phase: rnd(0, Math.PI * 2), amp: rnd(5, 12),
          pop: 0,
        };
        el.style.transform = `translate(${g.x}px, ${g.y}px) rotate(${g.rot}deg)`;
        glyphs.push(g);
      }

      const mouse = { x: -9999, y: -9999, on: false };
      hero.addEventListener("pointermove", (e) => {
        const r = hero.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
        mouse.on = true;
      });
      hero.addEventListener("pointerleave", () => {
        mouse.on = false; mouse.x = -9999; mouse.y = -9999;
      });

      const R = 130;
      function frame(t) {
        for (const g of glyphs) {
          g.x += g.vx;
          g.y += g.vy;
          g.rot += g.vr;
          if (g.y < -70) { g.y = H + 50; g.x = rnd(0, W); }
          if (g.x < -70) g.x = W + 50;
          else if (g.x > W + 70) g.x = -50;
          const bob = Math.sin(t * 0.001 + g.phase) * g.amp;
          let ox = 0, oy = 0;
          if (mouse.on) {
            const dx = g.x - mouse.x, dy = g.y + bob - mouse.y;
            const d = Math.hypot(dx, dy);
            if (d < R && d > 0.01) {
              const f = (R - d) / R, push = f * 40;
              ox = (dx / d) * push; oy = (dy / d) * push;
            }
          }
          g.pop *= 0.9;
          const sc = 1 + g.pop;
          g.el.style.transform = `translate(${g.x + ox}px, ${g.y + bob + oy}px) rotate(${g.rot}deg) scale(${sc})`;
        }
        raf = requestAnimationFrame(frame);
      }
      let raf, running = true;
      if (!reduce) raf = requestAnimationFrame(frame);
      document.addEventListener("visibilitychange", () => {
        if (reduce) return;
        running = !document.hidden;
        if (running) raf = requestAnimationFrame(frame);
        else cancelAnimationFrame(raf);
      });

      // ── Web Audio: play a short melody; each note pops a random glyph ──────
      const btn = document.getElementById("play-melody");
      const MELODY = [0, 4, 7, 9, 7, 12, 9, 5, 7, 4, 2, 0];
      const FREQ = MELODY.map((s) => 261.63 * Math.pow(2, s / 12));
      let actx = null, playing = false, timer = null, idx = 0;
      function noteOn(f, dur) {
        const o = actx.createOscillator(), g = actx.createGain();
        o.type = "triangle"; o.frequency.value = f;
        const t = actx.currentTime;
        g.gain.setValueAtTime(0.0001, t);
        g.gain.linearRampToValueAtTime(0.16, t + 0.02);
        g.gain.exponentialRampToValueAtTime(0.0008, t + dur);
        o.connect(g).connect(actx.destination);
        o.start(t); o.stop(t + dur + 0.03);
      }
      function ui(p) {
        btn.querySelector(".play-ico").classList.toggle("hidden", p);
        btn.querySelector(".pause-ico").classList.toggle("hidden", !p);
        btn.querySelector(".play-txt").textContent = p ? "Stop" : "Play melody";
        btn.setAttribute("aria-pressed", p ? "true" : "false");
      }
      function stop() { playing = false; clearInterval(timer); ui(false); }
      function start() {
        if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
        actx.resume(); playing = true; idx = 0; ui(true);
        const step = () => {
          if (!playing) return;
          noteOn(FREQ[idx % MELODY.length], 0.22);
          const g = glyphs[(Math.random() * glyphs.length) | 0];
          if (g) g.pop = 0.7;
          idx++;
        };
        step();
        timer = setInterval(step, 250);
      }
      btn && btn.addEventListener("click", () => (playing ? stop() : start()));
    })();
  </script>
</BaseLayout>
