---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../utils/url";

const projects = (await getCollection("research")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Research" description="Research projects.">
  <header class="prose-measure">
    <h1 class="text-3xl">Research</h1>
    <p class="muted mt-2">
      Selected projects on music neuroscience, EEG decoding, and BCIs.
    </p>
  </header>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      projects.map((p) => (
        <article class="card flex flex-col overflow-hidden">
          {p.data.image && (
            <img
              src={url(p.data.image)}
              alt={p.data.title}
              loading="lazy"
              class="mb-4 aspect-[16/9] w-full rounded-lg object-cover"
              style="border: 1px solid var(--border);"
            />
          )}
          <h2 class="text-lg">{p.data.title}</h2>
          <p class="muted mt-2 text-sm leading-relaxed">{p.data.summary}</p>

          {p.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {p.data.tags.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          )}

          {p.data.pub && (
            <p class="mt-4 text-sm">
              <a href={p.data.pub} target="_blank" rel="noopener">
                {p.data.pubLabel ?? "Related publication"} →
              </a>
            </p>
          )}
        </article>
      ))
    }
  </div>
</BaseLayout>
